# App
NODE_ENV=development
PORT=3000

# PostgreSQL — port hôte 5433 (docker-compose.yml), pour ne pas entrer en
# conflit avec un Postgres déjà présent sur le 5432 de la machine hôte.
DATABASE_URL=postgres://echango:echango@localhost:5433/echango_promo

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=30d

# Bootstrap admin — utilisé uniquement par `npm run seed:admin` si lancé
# sans arguments CLI (voir scripts/seed-admin.ts). Ne rien mettre ici en
# prod partagée : ce fichier .env local n'a pas vocation à être commité.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOM=

# S3 OVH (stockage des photos de promo)
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=echango-promo
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CDN_BASE_URL=

# Rétention images (jours) — §5.8 des specs
IMAGE_RETENTION_DAYS=30

# Durée de validité par défaut d'une promo (jours) — §3.2 des specs
PROMO_DEFAULT_DURATION_DAYS=5
