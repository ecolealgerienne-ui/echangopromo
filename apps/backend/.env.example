# App
NODE_ENV=development
PORT=3000

# CORS — origines web autorisées, séparées par des virgules (ex:
# https://admin.echango-promo.dz). Vide = aucune origine (l'app mobile
# n'est pas concernée par le CORS) ; à remplir seulement si un frontend
# web est ajouté.
CORS_ORIGINS=

# PostgreSQL — port hôte 5433 (docker-compose.yml), pour ne pas entrer en
# conflit avec un Postgres déjà présent sur le 5432 de la machine hôte.
DATABASE_URL=postgres://echango:echango@localhost:5433/echango_promo

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=30d

# Bootstrap admin — utilisé uniquement par `npm run seed:admin` si lancé
# sans arguments CLI (voir scripts/seed-admin.ts). Ne rien mettre ici en
# prod partagée : ce fichier .env local n'a pas vocation à être commité.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOM=

# S3 — OVH en prod, MinIO local (docker-compose) pour dev/test tant qu'aucun
# bucket OVH n'est configuré. Pour tester avec le mobile sur émulateur
# Android, S3_ENDPOINT doit être joignable par l'émulateur (10.0.2.2), donc
# nécessite le même netsh portproxy que le port 3000 (voir docs) : ajouter
# une règle listenport=9000 en plus de celle du 3000.
S3_ENDPOINT=http://10.0.2.2:9000
S3_REGION=us-east-1
S3_BUCKET=echango-promo
S3_ACCESS_KEY_ID=echango
S3_SECRET_ACCESS_KEY=echango123
S3_CDN_BASE_URL=

# Valeurs à utiliser à la place en prod avec un vrai bucket OVH :
# S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
# S3_REGION=gra
# S3_ACCESS_KEY_ID=<clé OVH>
# S3_SECRET_ACCESS_KEY=<secret OVH>

# Rétention images (jours) — §5.8 des specs
IMAGE_RETENTION_DAYS=30

# Durée de validité d'une promo (jours) — §3.2 des specs
PROMO_DEFAULT_DURATION_DAYS=5
PROMO_MAX_DURATION_DAYS=7

# App Links / Universal Links + fiches store (partage d'une promo,
# croissance organique) — servis par AppLinksController sur le sous-domaine
# promo.echango.com. Tout vide tant que l'app n'est pas publiée (aucune
# valeur ci-dessous n'est requise au démarrage) ; procédure complète et
# provenance de chaque valeur dans docs/DEPLOIEMENT_STORES.md.
PLAY_STORE_URL=
APP_STORE_URL=
ANDROID_PACKAGE_NAME=
ANDROID_SHA256_CERT_FINGERPRINT=
IOS_TEAM_ID=
IOS_BUNDLE_ID=
