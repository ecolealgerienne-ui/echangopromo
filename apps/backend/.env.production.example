# Modèle pour apps/backend/.env.production sur le VPS (docker-compose.promo.yml
# le charge via env_file). Ne jamais commiter le fichier réel — copier ce
# modèle en `.env.production` dans /opt/echangopromo/apps/backend/ et
# remplacer les valeurs. Voir docs/DEPLOIEMENT_VPS.md pour la procédure
# complète (migrations, seeds admin/commune).

NODE_ENV=production
PORT=3000

# CORS — pas de frontend web en V0, laisser vide tant qu'aucun n'est ajouté.
CORS_ORIGINS=

# PostgreSQL — hôte `postgres` = nom du service dans docker-compose.promo.yml
# (réseau Docker interne, pas de port publié sur l'hôte). Le mot de passe
# doit correspondre à POSTGRES_PASSWORD dans .env.promo (racine du repo).
DATABASE_URL=postgres://echango:<même-mot-de-passe-que-.env.promo>@postgres:5432/echango_promo

# JWT — secret long et aléatoire, différent de tout secret de dev
# (ex: openssl rand -base64 48).
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Bootstrap admin — laisser vide ici (le fichier .env.production tourne en
# continu sur le VPS). Fournir email/mot de passe/nom en arguments CLI au
# moment du seed plutôt que de les stocker en clair dans ce fichier :
#   docker compose -f docker-compose.promo.yml exec backend \
#     npm run seed:admin:prod -- admin@echango.com "mot-de-passe" "Nom"
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOM=

# S3 OVH (prod réelle, pas MinIO)
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=echango-promo
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CDN_BASE_URL=

# Rétention images (jours) — §5.8 des specs
IMAGE_RETENTION_DAYS=30

# Durée de validité d'une promo (jours) — §3.2 des specs
PROMO_DEFAULT_DURATION_DAYS=5
PROMO_MAX_DURATION_DAYS=7

# App Links / Universal Links + fiches store — tout vide tant que l'app
# n'est pas publiée (voir docs/DEPLOIEMENT_STORES.md).
PLAY_STORE_URL=
APP_STORE_URL=
ANDROID_PACKAGE_NAME=
ANDROID_SHA256_CERT_FINGERPRINT=
IOS_TEAM_ID=
IOS_BUNDLE_ID=
