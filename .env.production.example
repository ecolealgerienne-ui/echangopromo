# Modèle unique pour /opt/echangopromo/.env.production sur le VPS.
# Ne jamais commiter le fichier réel (gitignoré). Un seul fichier, utilisé
# de deux façons par docker-compose.promo.yml :
#   - comme --env-file (docker compose --env-file .env.production -f
#     docker-compose.promo.yml ...) pour la substitution ${...} dans le
#     fichier compose lui-même (POSTGRES_PASSWORD, BASE_DOMAIN) ;
#   - comme env_file: du service `backend`, donc injecté tel quel dans le
#     process NestJS (DATABASE_URL, JWT_SECRET, etc.).
# Les deux usages partagent POSTGRES_PASSWORD, ce qui élimine le risque de
# désync entre deux copies du même mot de passe (source d'un vrai incident
# de déploiement — voir docs/status_v0.md, entrée 2026-07-05).
#
# Voir docs/DEPLOIEMENT_VPS.md pour la procédure complète (migrations,
# seeds admin/commune).

# --- Lu par docker-compose.promo.yml (substitution ${...}) ---

# Mot de passe PostgreSQL du conteneur postgres de cette stack (interne,
# jamais exposé sur l'hôte). Choisir uniquement lettres/chiffres (éviter
# : / ? # [ ] @ ! $ & ' ( ) * + , ; = qui ont un sens spécial dans une URL
# et casseraient DATABASE_URL ci-dessous) — génération recommandée :
#   openssl rand -hex 24
# Pas de guillemets autour de la valeur (docker compose ne les retire pas).
POSTGRES_PASSWORD=change-me-alphanumeric-only

# Domaine racine, utilisé pour construire promo.${BASE_DOMAIN}. Déjà
# `echango.com` en prod (variable partagée avec la stack Traefik/Vendure).
BASE_DOMAIN=echango.com

# --- Lu par le process NestJS (env de app/backend) ---

NODE_ENV=production
PORT=3000

# CORS — pas de frontend web en V0, laisser vide tant qu'aucun n'est ajouté.
CORS_ORIGINS=

# PostgreSQL — hôte `postgres` = nom du service dans docker-compose.promo.yml
# (réseau Docker interne, pas de port publié sur l'hôte). Le mot de passe
# ci-dessous DOIT être exactement POSTGRES_PASSWORD ci-dessus (recopier la
# même valeur, ce fichier étant unique il n'y a plus qu'un seul endroit à
# éditer).
DATABASE_URL=postgres://echango:change-me-alphanumeric-only@postgres:5432/echango_promo

# JWT — secret long et aléatoire, différent de tout secret de dev
# (ex: openssl rand -base64 48).
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Bootstrap admin — laisser vide ici (ce fichier tourne en continu sur le
# VPS). Fournir email/mot de passe/nom en arguments CLI au moment du seed
# plutôt que de les stocker en clair dans ce fichier :
#   docker compose --env-file .env.production -f docker-compose.promo.yml \
#     exec backend npm run seed:admin:prod -- admin@echango.com "mot-de-passe" "Nom"
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOM=

# S3 OVH (prod réelle, pas MinIO)
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=echango-promo
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CDN_BASE_URL=

# Rétention images (jours) — §5.8 des specs
IMAGE_RETENTION_DAYS=30

# Durée de validité d'une promo (jours) — §3.2 des specs
PROMO_DEFAULT_DURATION_DAYS=5
PROMO_MAX_DURATION_DAYS=7

# App Links / Universal Links + fiches store — tout vide tant que l'app
# n'est pas publiée (voir docs/DEPLOIEMENT_STORES.md).
PLAY_STORE_URL=
APP_STORE_URL=
ANDROID_PACKAGE_NAME=
ANDROID_SHA256_CERT_FINGERPRINT=
IOS_TEAM_ID=
IOS_BUNDLE_ID=
