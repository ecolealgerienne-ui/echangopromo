# Variables lues par docker-compose.promo.yml lui-même (substitution
# ${...} dans le fichier compose, pas l'env de l'app NestJS — ça, c'est
# apps/backend/.env.production, voir .env.production.example).
#
# Sur le VPS : copier en `.env.promo` à la racine de /opt/echangopromo
# (docker compose --env-file .env.promo -f docker-compose.promo.yml ...
# ou renommer en `.env` si aucune autre stack ne partage ce répertoire).

# Mot de passe PostgreSQL du conteneur postgres de cette stack (interne,
# jamais exposé sur l'hôte) — doit correspondre au mot de passe dans
# DATABASE_URL de apps/backend/.env.production.
POSTGRES_PASSWORD=change-me

# Domaine racine, utilisé pour construire promo.${BASE_DOMAIN}. Déjà
# `echango.com` en prod (variable partagée avec la stack Traefik/Vendure).
BASE_DOMAIN=echango.com
